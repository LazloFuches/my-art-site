<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — Robert Egert Studio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/style.css">
  <link rel="stylesheet" href="/assets/css/glightbox.min.css">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Robert Egert",
    "url": "https://robertegert.com",
    "jobTitle": "Artist",
    "description": "Robert Egert is a painter based in New York.",
    "sameAs": ["https://www.instagram.com/robert_egert/"]
  }
  </script>
</head>
<body>
  <header>
    <div class="site-title"><a href="/">Robert Egert Studio</a></div>
    <nav>
      <a href="/bio/" class="{% if '/bio' in page.url %}active{% endif %}">Bio</a>
      <a href="/ephemera/" class="{% if '/ephemera' in page.url %}active{% endif %}">Ephemera</a>
      <a href="/contact/" class="{% if '/contact' in page.url %}active{% endif %}">Contact</a>
    </nav>
  </header>
  <main class="{{ layout | replace('.njk', '') }}">
    {{ content | safe }}
  </main>
  <footer>
    <p>© Robert Egert Studio</p>
  </footer>
  <script src="/assets/glightbox.min.js"></script>
  <script>
    const lightbox = GLightbox({
      touchNavigation: true,
      loop: false,
      autoplayVideos: false
    });
  </script>
</body>
</html>